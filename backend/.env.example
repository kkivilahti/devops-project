# Use these env values with docker-compose.yml:
# Change values like database user and password, jwt secret etc. for actual production use
NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/taskmanagement
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:8080
FRONTEND_PORT=8080

# Important:
# Set to true during initial production deployment to sync the database
# Switch back to false after the database has been synchronized
DB_SYNC=true


# =================================================
# Use these env values with docker-compose-dev.yml:
NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/taskmanagement
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
FRONTEND_PORT=5173

# Set to true during initial production deployment to sync the database
# Switch back to false after the database has been synchronized
DB_SYNC=false